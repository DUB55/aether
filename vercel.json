{
  "version": 2,
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.{ts,js}": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
