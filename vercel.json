{
  "version": 2,
  "outputDirectory": "dist",
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.ts"
    },
    {
      "src": "/icons/(.*)",
      "dest": "/icons/$1"
    },
    {
      "src": "/logo.png",
      "dest": "/logo.png"
    },
    {
      "src": "/privacy-policy",
      "dest": "/dist/index.html"
    },
    {
      "src": "/privacy",
      "dest": "/dist/index.html"
    },
    {
      "src": "/terms-of-service",
      "dest": "/dist/index.html"
    },
    {
      "src": "/terms",
      "dest": "/dist/index.html"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "dest": "/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "build": {
    "env": {
      "NODE_ENV": "production",
      "BUILD_TIMESTAMP": "2026-04-09-16-20"
    }
  }
}
