{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.ts"
    },
    {
      "src": "/privacy-policy.html",
      "dest": "/privacy-policy.html"
    },
    {
      "src": "/terms-of-service.html",
      "dest": "/terms-of-service.html"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "build": {
    "env": {
      "NODE_ENV": "production",
      "BUILD_TIMESTAMP": "2025-04-07-23-35"
    }
  }
}
