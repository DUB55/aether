{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/privacy-policy.html",
      "dest": "/privacy-policy.html"
    },
    {
      "src": "/terms-of-service.html",
      "dest": "/terms-of-service.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "GEMINI_API_KEYS": "@gemini-api-keys",
    "GEMINI_API_KEY": "@gemini-api-key",
    "APP_URL": "@app-url"
  },
  "functions": {
    "server.ts": {
      "maxDuration": 30
    }
  }
}
